# Server-side Gemini API key (used by /api/saju, /api/chat).
# Do NOT prefix with VITE_ — this must stay on the server only.
GEMINI_API_KEY=your_api_key_here

# Toss Payments — client key is safe to expose, secret must stay server-side.
VITE_TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key

# Supabase (auth + saved results). Anon key is safe to expose.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: admin unlock password for /admin route (default 'sajuai2025').
VITE_ADMIN_PASSWORD=
